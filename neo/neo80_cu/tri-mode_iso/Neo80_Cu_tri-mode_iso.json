        {"name": "WLO",      "title": "Lock WIN",                                "shortName": "QK_WLO"  },
        {"name": "SIX_N",    "title": "Full-key six-key switch",                 "shortName": "SIX_N"   },
        {"name": "IOS_SIRI", "title": "Outgoing SIRI",                           "shortName": "SIRI"    },
